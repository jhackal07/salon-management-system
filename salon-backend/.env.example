# PostgreSQL: use either DATABASE_URL or the PG_* variables below.
# Copy this file to .env and fill in your values.
# (Use .env for passwords with special characters like % < > so CMD doesn't break them.)

# Option A – single connection URL
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/salon_db

# Option B – separate variables (no special-character issues)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=yourpassword
# PG_DATABASE=salon_db
